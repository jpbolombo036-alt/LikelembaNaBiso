# Railway Environment Variables for Likelamba
# Copy relevant values to Railway dashboard (Settings -> Variables)

# Database (Railway PostgreSQL) - auto-injected via DATABASE_URL (RailwayEnvironmentPostProcessor)
SPRING_DATASOURCE_URL=jdbc:postgresql://<RAILWAY_POSTGRES_HOST>:5432/likelamba
SPRING_DATASOURCE_DRIVER_CLASS=org.postgresql.Driver
SPRING_DATASOURCE_USERNAME=<RAILWAY_POSTGRES_USER>
SPRING_DATASOURCE_PASSWORD=<RAILWAY_POSTGRES_PASSWORD>

# JWT Secret (base64 >= 256 bits) - A REMPLACER en production
JWT_SECRET=<your-base64-jwt-secret-at-least-256-bits>

# Server
SERVER_PORT=8080

# CORS (origines separees par virgules)
CORS_ALLOWED_ORIGINS=https://<ton-frontend>.vercel.app,http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Mobile Money (Orange / Free / Wave) : les callbacks sont en POST /api/paiements/callback (permitAll)
# Configure ici les identifiants selon les operateurs utilises.
